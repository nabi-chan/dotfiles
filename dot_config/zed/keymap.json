[
  {
    "context": "Workspace",
    "bindings": {
      "shift shift": "file_finder::Toggle"
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "alt-shift-up": "editor::DuplicateLineUp",
      "alt-shift-down": "editor::DuplicateLineDown"
    },
    "bindings": {
      "alt-shift-up": "editor::MoveLineUp",
      "alt-shift-down": "editor::MoveLineDown"
    }
  }
]
